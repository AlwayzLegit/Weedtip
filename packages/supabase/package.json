{
  "name": "@weedtip/supabase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./config": "./src/config.ts",
    "./queries": "./src/queries.ts",
    "./types": "./src/types/database.types.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "gen:types": "supabase gen types typescript --local --schema public > src/types/database.types.ts",
    "import:dispensaries": "node scripts/import-la-dispensaries.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@weedtip/shared": "workspace:*"
  },
  "devDependencies": {
    "supabase": "^2.2.1",
    "typescript": "^5.7.3"
  }
}
