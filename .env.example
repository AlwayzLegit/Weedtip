# ─────────────────────────────────────────────────────────────
# Weedtip — environment variables
# Copy to `.env` (root) and `apps/web/.env.local`, then fill in.
# Never commit real values. `.env*` is gitignored except this file.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
# Server-only. NEVER expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Supabase CLI (local dev / migrations)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# Maps — Mapbox (frontend map rendering). PostGIS handles all backend geo.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (placeholder — cannabis payment compliance handled separately)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Observability — Sentry (error + performance monitoring). Inert if unset.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Server-only: enables source-map upload during build (optional).
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Analytics — PostHog (product analytics). Inert if NEXT_PUBLIC_POSTHOG_KEY is unset.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Rate limiting — Upstash Redis (auth, checkout, webhook). Server-only.
# Fail-open: if unset, rate limiting is disabled (no requests are blocked).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
