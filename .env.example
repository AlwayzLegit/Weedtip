# ─────────────────────────────────────────────────────────────
# Weedtip — environment variables
# Copy to `.env` (root) and `apps/web/.env.local`, then fill in.
# Never commit real values. `.env*` is gitignored except this file.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
# Server-only. NEVER expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Supabase CLI (local dev / migrations)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# Maps — Mapbox (frontend map rendering). PostGIS handles all backend geo.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (placeholder — cannabis payment compliance handled separately)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
